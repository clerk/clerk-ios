    "Allow users to join the organization automatically or request to join based on a verified email domain." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "السماح للمستخدمين للأنضمام للمنظمة بشكل تلقائي أو عن طريق دعوة للأنضمام على نطاق بريد إلكتروني تم التحقق منه"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erlauben Sie Benutzern, der Organisation automatisch beizutreten oder den Beitritt auf der Grundlage einer verifizierten E-Mail-Domain anzufragen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Επιτρέψτε στους χρήστες να συμμετάσχουν στον οργανισμό αυτόματα ή να ζητήσουν συμμετοχή με βάση έναν επαληθευμένο τομέα email."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permita que los usuarios se unan a la organización automáticamente o soliciten unirse basándose en un dominio de correo electrónico verificado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permettre aux utilisateurs de rejoindre l'organisation automatiquement ou de faire une demande d'adhésion si leur domaine de messagerie est vérifié."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उपयोगकर्ताओं को स्वचालित रूप से संगठन में शामिल होने या सत्यापित ईमेल डोमेन के आधार पर शामिल होने का अनुरोध करने की अनुमति दें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Consenti agli utenti di unirsi automaticamente all'organizzazione oppure di richiedere di unirsi in base a un dominio email verificato."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "検証済みのメールドメインに基づいて、ユーザーが自動的に組織に参加するか、参加をリクエストすることを許可します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "인증된 이메일 도메인을 기준으로 사용자가 자동 참여하거나 참여 요청을 할 수 있게 해요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zezwalaj użytkownikom na automatyczne dołączanie do organizacji lub proszenie o dołączenie na podstawie zweryfikowanej domeny e-mail."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permita que os usuários se juntem à organização automaticamente ou solicitem participação com base em um domínio de e-mail verificado."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permite utilizatorilor să se alăture automat sau să solicite alăturarea pe baza unui domeniu de email verificat."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Разрешить пользователям присоединяться к организации автоматически или запрашивать присоединение на основе подтвержденного домена электронной почты."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kullanıcıların organizasyona otomatik olarak katılmasına veya doğrulanmış bir alan adı uzantılı e-posta ile katılma isteğinde bulunmasına izin verin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "允许用户根据已验证的电子邮件域名自动加入组织或请求加入。"
          }
        }
      }
    },
    "Alternatively, if your authenticator supports TOTP URIs, you can also copy the full URI." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بدلاً من ذلك، إذا كان المصادق الخاص بك يدعم عناوين TOTP URI، يمكنك أيضاً نسخ العنوان الكامل."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alternativ können Sie auch die vollständige URI kopieren, wenn Ihr Authenticator TOTP-URIs unterstützt."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εναλλακτικά, εάν ο επαληθευτής σας υποστηρίζει TOTP URIs, μπορείτε επίσης να αντιγράψετε το πλήρες URI."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alternativamente, si tu autenticador admite URIs TOTP, también puedes copiar la URI completa."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alternativement, si votre authentificateur prend en charge les URI TOTP, vous pouvez également copier l'URI complète."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "वैकल्पिक रूप से, यदि आपका प्रमाणीकरण TOTP URIs का समर्थन करता है, तो आप पूरा URI भी कॉपी कर सकते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "In alternativa, se il tuo autenticatore supporta gli URI TOTP, puoi anche copiare l'URI completo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "または、認証アプリがTOTP URIをサポートしている場合は、完全なURIをコピーすることもできます。"
