    "Add the domain to verify. Users with email addresses at this domain can join the organization automatically or request to join." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "أضف النطاق للتحقق. المستخدمين الذين لديهم عناوين بريد إلكتروني على هذا النطاق يمكنهم تسجيل الدخول إلى المنظمة بشكل تلقائي أو طلب الأنضمام."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fügen Sie die zu überprüfende Domain hinzu. Benutzer mit E-Mail-Adressen von dieser Domain können der Organisation automatisch beitreten oder einen Antrag auf Beitritt stellen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Προσθέστε τον τομέα για επαλήθευση. Χρήστες με διευθύνσεις email σε αυτόν τον τομέα μπορούν να συμμετάσχουν στον οργανισμό αυτόματα ή να αιτηθούν συμμετοχή."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Agregue el dominio para verificar. Los usuarios con direcciones de correo electrónico en este dominio pueden unirse a la organización automáticamente o solicitar unirse."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ajoutez le domaine pour le vérifier. Les utilisateurs possédant une adresse e-mail sur ce domaine peuvent rejoindre l'organisation automatiquement ou demander à y adhérer."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "सत्यापित करने के लिए डोमेन जोड़ें। इस डोमेन पर ईमेल पते वाले उपयोगकर्ता स्वचालित रूप से संगठन में शामिल हो सकते हैं या शामिल होने का अनुरोध कर सकते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aggiungi il dominio da verificare. Gli utenti con indirizzi email in questo dominio possono unirsi all’organizzazione automaticamente o richiedere di unirsi."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ドメインを追加して検証します。このドメインのメールアドレスを持つユーザーは、自動的に組織に参加するか、参加をリクエストすることができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "도메인을 추가해 인증하세요. 이 도메인의 이메일을 가진 사용자는 조직에 자동으로 참여하거나 참여 요청을 할 수 있어요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dodaj domenę do weryfikacji. Użytkownicy z adresami e-mail w tej domenie mogą automatycznie dołączyć do organizacji lub poprosić o dołączenie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adicione o domínio para verificar. Usuários com endereços de e-mail neste domínio podem se juntar à organização automaticamente ou solicitar participação."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Adaugă domeniul pentru verificare. Utilizatorii cu adrese de email pe acest domeniu se pot alătura automat sau pot solicita alăturarea."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Добавьте домен для подтверждения. Пользователи с адресами электронной почты в этом домене смогут присоединиться к организации автоматически или запросить присоединение."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Alan adını ekleyerek doğrulama yapın. Bu alana sahip e-posta adresleri ile kaydolan kullanıcılar organizasyona otomatik olarak katılabilir veya katılma talebi gönderebilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "添加域名以进行验证。具有此域名电子邮件地址的用户可以自动加入组织或请求加入。"
          }
        }
      }
    },
