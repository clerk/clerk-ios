    "Select an existing phone number to register for SMS code two-step verification or add a new one." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "اختر رقم هاتف موجود للتسجيل في التحقق بخطوتين عبر رمز الرسائل النصية أو أضف رقماً جديداً."
          }
        },
        "de" : {
          "stringUnit" : {
