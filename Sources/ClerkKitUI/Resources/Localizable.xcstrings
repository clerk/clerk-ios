        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आप एक नए डिवाइस से साइन इन कर रहे हैं। हम आपके खाते को सुरक्षित रखने के लिए सत्यापन मांग रहे हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Stai effettuando l'accesso da un nuovo dispositivo. Richiediamo la verifica per mantenere il tuo account sicuro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "新しいデバイスからサインインしています。アカウントを保護するために確認を求めています。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "새 기기에서 로그인하고 있습니다. 계정을 안전하게 유지하기 위해 확인을 요청하고 있습니다."
