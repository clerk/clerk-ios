    "You are no longer a member of this organization. Please choose another one." : {
      "comment" : "Error message displayed when the user is no longer a member of the organization.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لم تعد عضوًا في هذه المنظمة. يرجى اختيار منظمة أخرى."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie sind kein Mitglied dieser Organisation mehr. Bitte wählen Sie eine andere aus."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Δεν είστε πλέον μέλος αυτού του οργανισμού. Επιλέξτε έναν άλλον."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya no eres miembro de esta organización. Elige otra."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vous n’êtes plus membre de cette organisation. Veuillez en choisir une autre."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आप अब इस संगठन के सदस्य नहीं हैं। कृपया कोई दूसरा संगठन चुनें।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Non sei più membro di questa organizzazione. Scegline un'altra."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この組織のメンバーではなくなりました。別の組織を選択してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 조직의 멤버가 아닙니다. 다른 조직을 선택해 주세요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nie jesteś już członkiem tej organizacji. Wybierz inną."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Você não é mais membro desta organização. Escolha outra."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nu mai ești membru al acestei organizații. Alege alta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы больше не являетесь участником этой организации. Выберите другую."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Artık bu kuruluşun bir üyesi değilsiniz. Lütfen başka bir kuruluş seçin."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "您不再是该组织的成员。请选择其他组织。"
          }
        }
      }
    },
    "You are no longer a member of this organization. Please choose or create another one." : {
      "comment" : "Error message displayed when the user is no longer a member of the organization.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
