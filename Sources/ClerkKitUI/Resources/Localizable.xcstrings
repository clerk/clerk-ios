    "Users are automatically invited to join the organization when they sign-up and can join anytime." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تتم دعوة المستخدمين تلقائيًا للانضمام إلى المؤسسة عند تسجيل حساب جديد ويمكنهم الانضمام في أي وقت."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benutzer werden bei der Anmeldung automatisch eingeladen, der Organisation beizutreten, und können jederzeit beitreten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι χρήστες προσκαλούνται αυτόματα να συμμετάσχουν στον οργανισμό όταν εγγραφούν και μπορούν να συμμετάσχουν ανά πάσα στιγμή."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los usuarios son invitados automáticamente a unirse a la organización cuando se registran y pueden unirse en cualquier momento."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les utilisateurs sont automatiquement invités à rejoindre l'organisation lors de leur inscription et peuvent la rejoindre à tout moment."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उपयोगकर्ताओं को साइन-अप करने पर स्वचालित रूप से संगठन में शामिल होने के लिए आमंत्रित किया जाता है और वे कभी भी शामिल हो सकते हैं।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli utenti sono automaticamente invitati a unirsi all'organizzazione quando si registrano e possono unirsi in qualsiasi momento."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サインアップ時にユーザーは自動的に組織に招待され、いつでも参加することができます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사용자가 가입하면 자동으로 초대되고 언제든지 조직에 참여할 수 있어요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Użytkownicy są automatycznie zapraszani do organizacji podczas rejestracji i mogą dołączyć w dowolnym momencie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os usuários são convidados automaticamente a se juntar à organização quando se inscrevem e podem se juntar a qualquer momento."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilizatorii sunt invitați automat să se alăture organizației când se înregistrează și se pot alătura oricând."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пользователи автоматически приглашаются в организацию при регистрации и могут присоединиться в любое время."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kullanıcılar, kayıt olduklarında otomatik olarak organizasyona davet edilir ve istedikleri zaman katılabilirler."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用户在注册时会自动收到加入组织的邀请，并且可以随时加入。"
          }
        }
      }
    },
    "Users can only be invited manually to the organization." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يمكن دعوة المستخدمين يدويًا فقط للمؤسسة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benutzer können nur manuell in die Organisation eingeladen werden."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι χρήστες μπορούν να προσκληθούν μόνο χειροκίνητα στον οργανισμό."
