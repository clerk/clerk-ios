          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Użytkowników można zapraszać do organizacji tylko ręcznie."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os usuários só podem ser convidados manualmente para a organização."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilizatorii pot fi invitați manual doar în organizație."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пользователей можно только приглашать в организацию вручную."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kullanıcılar organizasyona sadece manuel olarak davet edilebilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用户只能被手动邀请加入组织。"
          }
        }
      }
    },
    "Users receive a suggestion to request to join, but must be approved by an admin before they are able to join the organization." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يتلقى المستخدمون اقتراحًا لطلب الانضمام ، ولكن يجب أن يوافق عليه المشرف قبل أن يتمكنوا من الانضمام إلى المنظمة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benutzer erhalten einen Vorschlag für eine Beitrittsanfrage, müssen aber von einem Administrator genehmigt werden, bevor sie der Organisation beitreten können."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι χρήστες λαμβάνουν μια πρόταση να ζητήσουν συμμετοχή, αλλά πρέπει να εγκριθούν από έναν διαχειριστή πριν μπορέσουν να συμμετάσχουν στον οργανισμό."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los usuarios reciben una sugerencia para solicitar unirse, pero deben ser aprobados por un administrador antes de poder unirse a la organización."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les utilisateurs reçoivent une suggestion d'adhésion à l'organisation, mais doivent être approuvés par un administrateur avant de pouvoir y adhérer."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उपयोगकर्ताओं को शामिल होने का अनुरोध करने का सुझाव मिलता है, लेकिन संगठन में शामिल होने से पहले व्यवस्थापक द्वारा अनुमोदित किया जाना चाहिए।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli utenti ricevono un suggerimento per richiedere di unirsi, ma devono essere approvati da un amministratore prima di poter accedere all'organizzazione."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ユーザーは組織への参加をリクエストする提案を受け取りますが、参加する前に管理者の承認が必要です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "사용자는 참여 요청 제안을 받지만, 관리자가 승인해야 조직에 참여할 수 있어요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Użytkownicy otrzymują sugestię, aby poprosić o dołączenie, ale zanim będą mogli dołączyć do organizacji, muszą zostać zatwierdzeni przez administratora."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os usuários recebem uma sugestão para solicitar participação, mas devem ser aprovados por um administrador antes de poderem se juntar à organização."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilizatorii primesc o sugestie de a solicita alăturarea, dar trebuie aprobați de un administrator înainte de a se putea alătura organizației."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пользователи получают предложение запросить присоединение, но администратор должен одобрить их, прежде чем они смогут присоединиться к организации."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kullanıcılar, katılma talebinde bulunmak için otomatik öneri alırlar; ancak organizasyona katılabilmeleri için bir yönetici onayı gereklidir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "用户会收到请求加入的建议，但在加入组织之前必须得到管理员的批准。"
          }
        }
      }
    },
    "Users who request to join your organization will appear here for review" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "سيظهر المستخدمون الذين يطلبون الانضمام إلى مؤسستك هنا للمراجعة"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benutzer, die darum bitten, Ihrer Organisation beizutreten, werden hier zur Überprüfung angezeigt"
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι χρήστες που ζητούν να συμμετάσχουν στον οργανισμό σας θα εμφανίζονται εδώ για έλεγχο"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los usuarios que soliciten unirse a tu organización aparecerán aquí para su revisión"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les utilisateurs qui demandent à rejoindre votre organisation apparaîtront ici pour examen"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "आपके संगठन में शामिल होने का अनुरोध करने वाले उपयोगकर्ता समीक्षा के लिए यहां दिखाई देंगे"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli utenti che richiedono di unirsi alla tua organizzazione appariranno qui per la revisione"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "組織への参加をリクエストしたユーザーは、確認のためここに表示されます"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "조직 참여를 요청한 사용자가 검토를 위해 여기에 표시됩니다"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Użytkownicy, którzy poproszą o dołączenie do organizacji, pojawią się tutaj do sprawdzenia"
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os usuários que solicitarem ingressar na sua organização aparecerão aqui para análise"
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilizatorii care solicită să se alăture organizației vor apărea aici pentru revizuire"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Пользователи, которые запросят присоединение к вашей организации, появятся здесь для проверки"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Organizasyonunuza katılmak isteyen kullanıcılar incelenmek üzere burada görünür"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "请求加入你组织的用户会显示在这里以供审核"
          }
        }
      }
    },
    "Users won't be able to join the organization automatically after this." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لن يتمكن المستخدمون من الانضمام إلى المؤسسة تلقائيًا بعد ذلك."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Benutzer können der Organisation danach nicht mehr automatisch beitreten."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Οι χρήστες δεν θα μπορούν να συμμετάσχουν στον οργανισμό αυτόματα μετά από αυτό."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Los usuarios no podrán unirse a la organización automáticamente después de esto."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les utilisateurs ne pourront plus rejoindre l'organisation automatiquement après cela."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "उपयोगकर्ता इसके बाद स्वचालित रूप से संगठन में शामिल नहीं हो पाएंगे।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gli utenti non potranno più unirsi automaticamente all'organizzazione dopo questo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "この後、ユーザーは自動的に組織に参加することができなくなります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이후에는 사용자가 조직에 자동으로 참여할 수 없어요."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Po tym użytkownicy nie będą mogli automatycznie dołączać do organizacji."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Os usuários não poderão mais se juntar à organização automaticamente após isso."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Utilizatorii nu se vor mai putea alătura automat organizației după aceasta."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "После этого пользователи не смогут присоединяться к организации автоматически."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kullanıcılar bundan sonra organizasyona otomatik olarak katılamayacaklar."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "此后，用户将无法自动加入组织。"
          }
        }
      }
    },
    "Using your passkey confirms it's you. Your device may ask for your fingerprint, face or screen lock." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "استخدام مفتاح المرور الخاص بك يؤكد هويتك. قد يطلب جهازك بصمة إصبعك أو وجهك أو قفل الشاشة."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Verwendung Ihrer Passkey bestätigt, dass Sie es sind. Ihr Gerät kann Sie nach Ihrer Fingerabdruck, Gesicht oder Bildschirmsperre fragen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Η χρήση του passkey σας επιβεβαιώνει ότι είστε εσείς. Η συσκευή σας μπορεί να ζητήσει το δακτυλικό σας αποτύπωμα, το πρόσωπό σας ή τον κωδικό κλειδώματος οθόνης."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El uso de tu clave de acceso confirma que eres tú. Tu dispositivo puede solicitar tu huella digital, rostro o bloqueo de pantalla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'utilisation de votre clé d'accès confirme votre identité. Votre appareil peut vous demander votre empreinte digitale, votre visage ou votre code de verrouillage."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "अपना पासकी उपयोग करने से पुष्टि होती है कि यह आप ही हैं। आपका डिवाइस आपका फिंगरप्रिंट, फेस या स्क्रीन लॉक मांग सकता है।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "L'uso della tua passkey conferma che sei tu. Il tuo dispositivo potrebbe richiedere l'impronta digitale, il riconoscimento facciale o il blocco schermo."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "パスキーを使用することで本人確認ができます。デバイスが指紋、顔認証、画面ロックを要求する場合があります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "패스키를 사용하면 본인임을 확인할 수 있습니다. 기기에서 지문, 얼굴 또는 화면 잠금을 요구할 수 있습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Użycie klucza dostępu potwierdza, że to Ty. Urządzenie może poprosić o odcisk palca, twarz lub blokadę ekranu."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Usar sua chave de acesso confirma que é você. Seu dispositivo pode solicitar sua impressão digital, rosto ou bloqueio de tela."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Folosirea cheii de acces confirmă că ești tu. Dispozitivul poate solicita amprenta, fața sau blocarea ecranului."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Использование ключа доступа подтверждает, что это вы. Устройство может запросить отпечаток пальца, распознавание лица или блокировку экрана."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geçiş anahtarınızı kullanmak kimliğinizi doğrular. Cihazınız parmak izi, yüz tanıma veya ekran kilidi isteyebilir."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "使用您的通行密钥可确认您的身份。您的设备可能会要求您提供指纹、面容或屏幕锁定。"
          }
        }
      }
    },
