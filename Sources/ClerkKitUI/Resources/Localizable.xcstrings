    "If you have trouble completing required account setup, email us and we will help you finish as soon as possible." : {
      "comment" : "Subtitle text for the \"Session Task\" context in the \"Get help\" view.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا كانت لديك مشكلة في إكمال إعداد الحساب المطلوب، راسلنا عبر البريد الإلكتروني وسنساعدك على الانتهاء في أقرب وقت ممكن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie Probleme bei der Einrichtung des erforderlichen Kontos haben, senden Sie uns eine E-Mail. Wir helfen Ihnen dann, die Einrichtung so schnell wie möglich abzuschließen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Εάν αντιμετωπίζετε προβλήματα με την ολοκλήρωση της απαιτούμενης ρύθμισης λογαριασμού, στείλτε μας email και θα σας βοηθήσουμε να ολοκληρώσετε το συντομότερο δυνατό."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tiene problemas para completar la configuración de cuenta requerida, envíenos un correo electrónico y lo ayudaremos a terminar lo antes posible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous rencontrez des difficultés pour terminer la configuration de compte requise, envoyez-nous un e-mail et nous vous aiderons à terminer dès que possible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि आपको आवश्यक खाता सेटअप पूरा करने में परेशानी हो रही है, तो हमें ईमेल करें और हम इसे जल्द से जल्द पूरा करने में आपकी सहायता करेंगे।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se riscontri problemi nel completare la configurazione dell'account richiesta, inviaci un'e-mail e ti aiuteremo a completare il prima possibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "必要なアカウント設定を完了できない場合は、メールでお問い合わせください。できるだけ早く完了するようお手伝いいたします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "필수 계정 설정을 완료하는 데 문제가 있는 경우 이메일을 보내주시면 최대한 빨리 완료하도록 도와드리겠습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli masz problem z ukończeniem wymaganej konfiguracji konta, napisz do nas, a pomożemy Ci ją dokończyć tak szybko, jak to możliwe."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você tiver problemas para concluir a configuração necessária da conta, envie-nos um e-mail e nós o ajudaremos a terminar o mais rápido possível."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă ai probleme la finalizarea configurării obligatorii a contului, trimite-ne un email și te vom ajuta să finalizezi cât mai curând posibil."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если у вас возникли проблемы с завершением обязательной настройки учетной записи, напишите нам, и мы поможем завершить ее как можно скорее."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesap kurulumunu tamamlamakta sorun yaşıyorsanız bize e-posta gönderin, en kısa sürede yardımcı olalım."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您在完成所需的帐户设置时遇到困难，请给我们发送电子邮件，我们将帮助您尽快完成。"
          }
        }
      }
    },
    "If you have trouble creating your account, email us and we will work with you to complete your registration as soon as possible." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا واجهت مشكلة في إنشاء حسابك، أرسل لنا بريداً إلكترونياً وسنعمل معك لإكمال تسجيلك في أقرب وقت ممكن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie Probleme beim Erstellen Ihres Kontos haben, senden Sie uns eine E-Mail und wir werden mit Ihnen zusammenarbeiten, um Ihre Registrierung so schnell wie möglich abzuschließen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν έχετε πρόβλημα με τη δημιουργία του λογαριασμού σας, στείλτε μας email και θα συνεργαστούμε μαζί σας για να ολοκληρώσουμε την εγγραφή σας το συντομότερο δυνατό."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tienes problemas para crear tu cuenta, envíanos un correo electrónico y trabajaremos contigo para completar tu registro lo antes posible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous avez des difficultés à créer votre compte, envoyez-nous un e-mail et nous travaillerons avec vous pour finaliser votre inscription dès que possible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि आपको अपना खाता बनाने में परेशानी हो रही है, तो हमें ईमेल करें और हम आपके साथ काम करेंगे ताकि जल्द से जल्द आपका पंजीकरण पूरा हो सके।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se hai problemi a creare il tuo account, inviaci una email e lavoreremo con te per completare la tua registrazione il prima possibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントの作成で問題が発生した場合は、メールでご連絡ください。できるだけ早く登録を完了できるよう対応いたします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정 생성에 문제가 있으시면 이메일로 문의해 주세요. 최대한 빨리 등록을 완료하도록 도와드리겠습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli masz problem z utworzeniem konta, napisz do nas, a pomożemy dokończyć rejestrację tak szybko, jak to możliwe."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você tiver problemas para criar sua conta, envie-nos um e-mail e trabalharemos com você para concluir seu cadastro o mais rápido possível."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă ai probleme la crearea contului, trimite-ne un email și vom lucra cu tine pentru a finaliza înregistrarea cât mai curând posibil."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если у вас возникли проблемы с созданием учетной записи, напишите нам, и мы поможем завершить регистрацию как можно скорее."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesap oluştururken sorun yaşıyorsanız bize e-posta gönderin, kaydınızı en kısa sürede tamamlayalım."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您在创建账户时遇到问题，请发送电子邮件给我们，我们将与您合作尽快完成您的注册。"
          }
        }
      }
    },
    "If you have trouble signing into your account, email us and we will work with you to restore access as soon as possible." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "إذا واجهت مشكلة في تسجيل الدخول إلى حسابك، أرسل لنا بريداً إلكترونياً وسنعمل معك لاستعادة الوصول في أقرب وقت ممكن."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn Sie Probleme beim Anmelden auf Ihrem Konto haben, senden Sie uns eine E-Mail und wir werden mit Ihnen zusammenarbeiten, um den Zugang so schnell wie möglich wiederherzustellen."
          }
        },
        "el" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Αν έχετε πρόβλημα με την είσοδό σας στον λογαριασμό σας, στείλτε μας email και θα συνεργαστούμε μαζί σας για την αποκατάσταση της πρόσβασης το συντομότερο δυνατό."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si tienes problemas para iniciar sesión en tu cuenta, envíanos un correo electrónico y trabajaremos contigo para restaurar el acceso lo antes posible."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous avez des difficultés à vous connecter à votre compte, envoyez-nous un e-mail et nous travaillerons avec vous pour rétablir l'accès dès que possible."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "यदि आपको अपने खाते में साइन इन करने में परेशानी हो रही है, तो हमें ईमेल करें और हम आपके साथ काम करेंगे ताकि जल्द से जल्द पहुंच बहाल की जा सके।"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se hai problemi ad accedere al tuo account, inviaci una email e lavoreremo con te per ripristinare l'accesso il prima possibile."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "アカウントへのサインインで問題が発生した場合は、メールでご連絡ください。できるだけ早くアクセスを復元できるよう対応いたします。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "계정 로그인에 문제가 있으시면 이메일로 문의해 주세요. 최대한 빨리 접근 권한을 복구하도록 도와드리겠습니다."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jeśli masz problem z zalogowaniem się na konto, napisz do nas, a pomożemy przywrócić dostęp tak szybko, jak to możliwe."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se você tiver problemas para entrar na sua conta, envie-nos um e-mail e trabalharemos com você para restaurar o acesso o mais rápido possível."
          }
        },
        "ro" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dacă ai probleme la autentificarea în cont, trimite-ne un email și vom lucra cu tine pentru a restabili accesul cât mai curând posibil."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если у вас возникли проблемы со входом в учетную запись, напишите нам, и мы поможем восстановить доступ как можно скорее."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hesabınıza giriş yapmakta sorun yaşıyorsanız bize e-posta gönderin, erişiminizi en kısa sürede geri yükleyelim."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果您在登录账户时遇到问题，请发送电子邮件给我们，我们将与您合作尽快恢复访问权限。"
          }
        }
      }
    },
