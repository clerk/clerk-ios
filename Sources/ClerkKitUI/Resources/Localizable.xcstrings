        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "¿Está seguro de que desea abandonar esta organización? Perderá el acceso a esta organización y sus aplicaciones."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Êtes-vous sûr de vouloir quitter cette organisation ? Vous perdrez l'accès à cette organisation et à ses applications."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "क्या आप वाकई इस संगठन को छोड़ना चाहते हैं? आप इस संगठन और इसके अनुप्रयोगों तक पहुंच खो देंगे।"
